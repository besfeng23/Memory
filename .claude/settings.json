{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run build)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.vercel/**)",
      "Read(.supabase/**)",
      "Read(secrets/**)",
      "Bash(env)",
      "Bash(printenv)"
    ]
  }
}
